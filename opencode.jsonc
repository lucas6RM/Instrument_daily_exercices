{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "mastermind",
  "agent": {
    "mastermind": {
      "mode": "primary",
      "instructions": ".opencode/agents/mastermind.md",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "cp*": "allow",
        },
        "task": {
          "*": "deny",
          "worker": "allow",
          "reviewer": "allow",
        },
      },
    },
    "worker": {
      "mode": "subagent",
      "instructions": ".opencode/agents/worker.md",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": {
          ".opencode/*": "deny",
          "*": "allow",
        },
        "bash": "allow",
        "task": "deny",
      },
    },
    "reviewer": {
      "mode": "subagent",
      "instructions": ".opencode/agents/reviewer.md",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": {
          ".opencode/todo.md": "allow",
          "*": "deny",
        },
        "bash": "allow",
        "task": "deny",
      },
    },
  },
  "mcp": {
    "model-switcher": {
      "enabled": false
    }
  },
}
